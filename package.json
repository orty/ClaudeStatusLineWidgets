{
  "name": "claude-statusline-widgets",
  "version": "1.0.0",
  "type": "module",
  "description": "Claude Code statusline with cache TTL countdown and interactive TUI configurator",
  "main": "dist/index.js",
  "types": "dist/extension-api.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./extension-api": {
      "types": "./dist/extension-api.d.ts",
      "default": "./dist/extension-api.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    ".claude-plugin/",
    "hooks/",
    "skills/",
    "install-global.js"
  ],
  "scripts": {
    "prepare": "node scripts/prepare.js",
    "build": "node scripts/build.js",
    "test": "vitest run",
    "dev": "tsc --watch",
    "postinstall": "node install-global.js"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "undici": ">=7.28.0",
    "@actions/http-client": {
      "undici": "6.27.0"
    },
    "npm": {
      "undici": "6.27.0"
    },
    "node-gyp": {
      "undici": "6.27.0"
    }
  }
}
